# Application
APP_ENV=development
APP_DEBUG=True

# Service port
PORT=8002

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000

# Django backend base URL (catalog/order tools call this)
DJANGO_API_URL=http://localhost:8000

# Analytics microservice base URL (trending/top-books tools call this)
ANALYTICS_SERVICE_URL=http://localhost:8001

# ============================================================
# LLM provider — OpenRouter (OpenAI-compatible API) for the tool-calling loop
# ============================================================
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=deepseek/deepseek-v3.2

# Max tool-calling iterations per chat turn (safety bound)
AGENT_MAX_ITERATIONS=6

# ============================================================
# Auth — verify JWT access tokens issued by the Django backend
# ============================================================
# JWT_SECRET MUST equal the Django backend's SECRET_KEY (the backend signs
# simplejwt access tokens with it using HS256). Tokens are verified locally —
# no extra call to the backend.
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_USER_ID_CLAIM=user_id

# Require a valid Bearer token on /chat and /recommendations.
# Set to False for local development to make auth optional.
REQUIRE_AUTH=True
