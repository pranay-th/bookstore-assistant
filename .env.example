# Application
APP_ENV=development
APP_DEBUG=True

# Service port
PORT=8002

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000

# Django backend base URL (catalog/order tools call this)
DJANGO_API_URL=http://localhost:8000

# Analytics microservice base URL (trending/top-books tools call this)
ANALYTICS_SERVICE_URL=http://localhost:8001

# ============================================================
# LLM provider — OpenRouter (OpenAI-compatible API) for the tool-calling loop
# ============================================================
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=deepseek/deepseek-v3.2

# Max tool-calling iterations per chat turn (safety bound)
AGENT_MAX_ITERATIONS=6
